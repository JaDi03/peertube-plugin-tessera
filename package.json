{
  "name": "peertube-plugin-tessera",
  "version": "1.1.0",
  "description": "Companion bridge for Tessera enabling decentralized per-second billing on PeerTube.",
  "engine": {
    "peertube": ">= 6.0.0"
  },
  "main": "dist/main.js",
  "clientScripts": [
    {
      "script": "dist/client.js",
      "scopes": [
        "video-watch",
        "video-embed",
        "video-edit",
        "common"
      ]
    }
  ],
  "scripts": {
    "build": "tsc && esbuild src/client.ts --bundle --outfile=dist/client.js --format=esm",
    "test": "vitest run",
    "lint": "eslint"
  },
  "author": "JaDi03",
  "homepage": "https://github.com/JaDi03/peertube-plugin-tessera",
  "bugs": "https://github.com/JaDi03/peertube-plugin-tessera/issues",
  "library": "peertubePluginTessera",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@peertube/peertube-types": "^8.2.0",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
